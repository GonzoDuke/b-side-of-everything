---
import PieceLayout from '../layouts/PieceLayout.astro';
import { PIECES } from '../data/pieces.js';
import Candlemakers from '../components/pieces/Candlemakers.jsx';

const piece = PIECES.find(p => p.id === 'candlemakers');
---

<PieceLayout piece={piece}>
  <Candlemakers client:load />
</PieceLayout>
