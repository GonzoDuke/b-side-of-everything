---
import BaseLayout from '../layouts/BaseLayout.astro';

const S = {
  bg: "#1a1714",
  text: "#f0ece4",
  textDim: "rgba(240,236,228,0.65)",
  textGhost: "rgba(240,236,228,0.4)",
  rule: "rgba(240,236,228,0.12)",
  buttonBorder: "rgba(240,236,228,0.2)",
  buttonText: "rgba(240,236,228,0.55)",
};
---

<BaseLayout title="Not Found — The B-Side of Everything">
  <div style={`background: ${S.bg}; min-height: 100vh; display: flex; align-items: center; justify-content: center;`}>
    <div style="max-width: 480px; padding: 40px 32px; text-align: center;">
      <div style={`
        font-family: var(--mono); font-size: 12px; color: ${S.textGhost};
        letter-spacing: 0.15em; margin-bottom: 24px;
      `}>404</div>

      <h1 style={`
        font-family: var(--serif); font-size: 28px; font-weight: 400;
        color: ${S.text}; margin: 0 0 16px;
      `}>Nothing here.</h1>

      <p style={`
        font-family: var(--body); font-size: 15px; line-height: 1.7;
        color: ${S.textDim}; font-style: italic; margin: 0 0 32px;
      `}>
        Whatever was at this address either moved, never existed, or
        survived only in someone's memory. That happens more than you'd think.
      </p>

      <a href="/" style={`
        background: none; border: 1px solid ${S.buttonBorder}; border-radius: 4px;
        font-family: var(--mono); font-size: 11px; font-weight: 400; letter-spacing: 0.06em;
        color: ${S.buttonText}; padding: 8px 20px; text-decoration: none;
        display: inline-block;
      `}>&larr; Back to the Archive</a>
    </div>
  </div>
</BaseLayout>
